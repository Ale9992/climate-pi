# Python
.venv/
__pycache__/
*.pyc

# Database e log (runtime)
db/*.db
db/*.db-wal
db/*.db-shm
logs/

# Segreti / credenziali generate dal mapping tool
config/.dirigera_token
config/config.yaml
config/*.bak_*

# Parametri/modelli calibrati sulla CASA specifica (non generici): un nuovo
# utente parte dai default fisici e il calibratore li ri-genera.
config/thermal_params*.json
config/ac_models.json

# Strumenti di diagnosi/calibrazione e test (specifici di casa, fuori dal repo
# pubblico): contengono script personali (es. MacBook kiosk) e fixture interne.
tools/
tests/

# Dashboard
dashboard/node_modules/
dashboard/dist/

# OS
.DS_Store

# --- Sicurezza extra (pubblicazione) ---
# Tutti i config tranne il template di esempio
config/*.yaml
!config/config.example.yaml
# Backup e file temporanei
*.bak
*.bak_*
*.legacy.*
.panasonic-settings
# Eventuali credenziali/segreti
*.token
*.key
.env
.env.*
